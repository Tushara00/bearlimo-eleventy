---
title: "About Bear Limo"
permalink: "/about/"
layout: "base.njk"
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
  <meta name="theme-color" content="#000000">
  <title>{{ about.seo.meta_title }}</title>
  <meta name="description" content="{{ about.seo.meta_description }}">
  <link class="canonical" href="https://bearlimo.com/about.html">
  <meta name="robots" content="index,follow,max-image-preview:large">
  
  <link rel="stylesheet" href="/assets/css/styles.css">
  <style>
    @media (max-width: 960px) {
      .container-split { grid-template-columns: 1fr !important; }
      aside { position: static !important; margin-top: 48px; }
    }
  </style>
</head>
<body>

  <main id="main">
    <section class="section" style="padding-top: clamp(40px, 6vw, 80px);">
      <div class="container container-split" style="display: grid; grid-template-columns: 3fr 1fr; gap: clamp(32px, 5vw, 64px); align-items: start;">
        
        <!-- Left Column: CMS Parsed Text Layout -->
        <div class="prose" style="max-width: 100%;">
          <span class="eyebrow" style="margin-bottom: 8px;">{{ about.content_blocks.eyebrow }}</span>
          <h1 style="margin-bottom: 24px;">{{ about.content_blocks.h1 }}</h1>
          
          <figure style="margin: 0 0 40px; border: 1px solid var(--line);">
            <img src="/{{ about.content_blocks.hero_image }}" alt="Bear Limo Executive Fleet" style="width: 100%; height: auto; display: block;">
          </figure>

          <div class="markdown-body">
            {{ about.content_blocks.body_text | markdown | safe }}
          </div>
        </div>

        <!-- Right Column: Corporate Values Sidebar -->
        <aside style="display: flex; flex-direction: column; gap: 32px; position: sticky; top: 100px;">
          <span class="eyebrow" style="color: var(--muted); border-bottom: 1px solid var(--line); padding-bottom: 12px; margin: 0;">Our Values</span>
          
          {% for value in about.core_values %}
            <blockquote style="margin: 0; padding: 0; {% if loop.index > 1 %}border-top: 1px solid var(--line); padding-top: 24px;{% endif %}">
              <p style="font-family: var(--f-display); font-size: 1.15rem; font-weight: 600; color: #fff; line-height: 1.4; margin-bottom: 8px;">{{ value.value_title }}</p>
              <p style="font-size: 0.9rem; color: var(--muted); margin: 0; line-height: 1.5;">{{ value.value_description }}</p>
            </blockquote>
          {% endfor %}
        </aside>

      </div>
    </section>

    <!-- Conversion CTA -->
    <section class="cta-band">
      <div class="container">
        <span class="eyebrow" style="color:#555">Secure Booking Engine</span>
        <h2 style="margin-bottom:.35em">Experience Premium Nationwide Travel</h2>
        <p style="max-width:52ch;margin:0 auto 32px;color:#444">Secure your vehicle instantly via our simple online reservation platform.</p>
        <div style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap">
          <a class="btn btn-solid" href="https://app.myridesync.com/quote?uid=grandlimousine" rel="noopener" target="_blank">Book Online Now</a>
          <a class="btn" href="tel:+14044244499">Call Support: (404) 424-4499</a>
        </div>
      </div>
    </section>
  </main>

</body>
</html>